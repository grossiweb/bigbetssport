# Next.js relies on styled-jsx being top-level resolvable. pnpm's strict
# linking doesn't hoist it by default, which breaks `next build`. Hoist
# the Next.js peer deps so Node's require can find them.
public-hoist-pattern[]=*styled-jsx*
public-hoist-pattern[]=*next*
public-hoist-pattern[]=*@types*
public-hoist-pattern[]=*@swc*
auto-install-peers=true
strict-peer-dependencies=false
