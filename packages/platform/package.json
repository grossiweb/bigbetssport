{
  "name": "@bbs/platform",
  "version": "0.1.0",
  "private": true,
  "description": "Big Ball Sports developer platform \u2014 dashboard, docs, status page.",
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "tsc --noEmit -p tsconfig.json",
    "build:next": "next build",
    "start": "next start -p 3001",
