{
  "name": "@bbs/orchestrator",
  "version": "0.1.0",
  "private": true,
  "description": "Source selection, quota tracking, and circuit-breaker logic.",
  "type": "module",
  "main": "./src/index.ts",
  "bin": {
    "bbs-orchestrator": "./src/main.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "dev": "tsx watch --env-file=../../.env src/main.ts",
    "start": "tsx src/main.ts",
    "ingest:rundown": "tsx --env-file=../../.env scripts/ingest-rundown.ts",
    "ingest:rundown:prod": "tsx scripts/ingest-rundown.ts",
    "enrich:thesportsdb": "tsx --env-file=../../.env scripts/enrich-thesportsdb.ts",
    "enrich:thesportsdb:prod": "tsx scripts/enrich-thesportsdb.ts",
    "ingest:standings": "tsx --env-file=../../.env scripts/ingest-standings-espn.ts",
    "ingest:standings:prod": "tsx scripts/ingest-standings-espn.ts",
    "ingest:players": "tsx --env-file=../../.env scripts/ingest-players-thesportsdb.ts",
    "ingest:players:prod": "tsx scripts/ingest-players-thesportsdb.ts",
    "ingest:stats": "tsx --env-file=../../.env scripts/ingest-espn-stats.ts",
    "ingest:stats:prod": "tsx scripts/ingest-espn-stats.ts",
    "ingest:fpl": "tsx --env-file=../../.env scripts/ingest-fpl.ts",
    "ingest:fpl:prod": "tsx scripts/ingest-fpl.ts",
    "ingest:nhl": "tsx --env-file=../../.env scripts/ingest-nhl.ts",
    "ingest:nhl:prod": "tsx scripts/ingest-nhl.ts",
    "ingest:openf1": "tsx --env-file=../../.env scripts/ingest-openf1.ts",
    "ingest:openf1:prod": "tsx scripts/ingest-openf1.ts",
    "ingest:mlb": "tsx --env-file=../../.env scripts/ingest-mlb.ts",
    "ingest:mlb:prod": "tsx scripts/ingest-mlb.ts",
    "ingest:openligadb": "tsx --env-file=../../.env scripts/ingest-openligadb.ts",
    "ingest:openligadb:prod": "tsx scripts/ingest-openligadb.ts",
    "ingest:cricket": "tsx --env-file=../../.env scripts/ingest-cricket.ts",
    "ingest:cricket:prod": "tsx scripts/ingest-cricket.ts",
    "ingest:pandascore": "tsx --env-file=../../.env scripts/ingest-pandascore.ts",
    "ingest:pandascore:prod": "tsx scripts/ingest-pandascore.ts",
    "ingest:balldontlie": "tsx --env-file=../../.env scripts/ingest-balldontlie.ts",
    "ingest:balldontlie:prod": "tsx scripts/ingest-balldontlie.ts",
    "ingest:football-data": "tsx --env-file=../../.env scripts/ingest-football-data.ts",
    "ingest:football-data:prod": "tsx scripts/ingest-football-data.ts",
    "ingest:cfb": "tsx --env-file=../../.env scripts/ingest-cfb.ts",
    "ingest:cfb:prod": "tsx scripts/ingest-cfb.ts",
    "ingest:api-sports": "tsx --env-file=../../.env scripts/ingest-api-sports.ts",
    "ingest:api-sports:prod": "tsx scripts/ingest-api-sports.ts",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src"
  },
  "dependencies": {
    "@bbs/shared": "workspace:*",
    "bullmq": "^5.28.1",
    "fastify": "^4.28.1",
    "ioredis": "^5.4.1",
    "pg": "^8.13.1",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10",
    "ioredis-mock": "^8.9.0",
    "msw": "^2.6.6"
  }
}
