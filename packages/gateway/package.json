{
  "name": "@bbs/gateway",
  "version": "0.1.0",
  "private": true,
  "description": "Public REST / GraphQL / WebSocket gateway.",
  "type": "module",
  "main": "./src/index.ts",
  "bin": {
    "bbs-gateway": "./src/main.ts"
  },
  "scripts": {
