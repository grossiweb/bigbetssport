    "bullmq": "^5.28.1",
    "fastify": "^4.28.1",
    "fastify-plugin": "^4.5.1",
    "graphql": "^16.9.0",
    "graphql-yoga": "^5.10.3",
    "ioredis": "^5.4.1",
    "pg": "^8.13.1",
    "prom-client": "^15.1.3",
