# ---------------------------------------------------------------------------
# Big Ball Sports — environment template
# Copy to `.env` for local dev. Never commit secrets.
# ---------------------------------------------------------------------------

# Core infrastructure -------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=info

# Postgres (TimescaleDB image) ----------------------------------------------
DATABASE_URL=postgres://bbs:bbs@localhost:5432/bbs
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=bbs
POSTGRES_USER=bbs
POSTGRES_PASSWORD=bbs

# Redis ----------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# Service ports --------------------------------------------------------------
GATEWAY_PORT=3000
ORCHESTRATOR_PORT=3006
NORMALISER_PORT=3007
MCP_FLEET_PORT=3008
LIVE_WINDOW_PORT=3009

# Observability --------------------------------------------------------------
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

# pgAdmin (dev-only) ---------------------------------------------------------
PGADMIN_PORT=5050
PGADMIN_DEFAULT_EMAIL=admin@bigballsports.local
PGADMIN_DEFAULT_PASSWORD=admin

# ---------------------------------------------------------------------------
# Upstream source API keys
# Fill these in as each SourceConfig ships. Leave blank if unused.
# ---------------------------------------------------------------------------
# Tier 1 — football/soccer
API_FOOTBALL_KEY=
FOOTBALL_DATA_KEY=
SPORTMONKS_KEY=

# Tier 1 — North American leagues
SPORTRADAR_KEY=
ESPN_KEY=
MYSPORTSFEEDS_KEY=

# Tier 1 — odds / betting
THE_ODDS_API_KEY=
OPTIC_ODDS_KEY=

# Tier 2 — extended coverage
CRICBUZZ_KEY=
CRICKETDATA_KEY=
SPORTSDATAIO_KEY=
RAPIDAPI_KEY=

# MCP fleet
MCP_FLEET_BASE_URL=http://localhost:3008

# ---------------------------------------------------------------------------
# Auth / API keys served by the gateway itself (hash salt, JWT secret, etc.)
# ---------------------------------------------------------------------------
API_KEY_HASH_SALT=change-me-in-production
ADMIN_KEY=change-me-in-production
API_KEYS_JSON=[]
PLATFORM_SHARED_SECRET=change-me-in-production

# ---------------------------------------------------------------------------
# Platform (packages/platform) — Next.js dashboard + docs + status
# ---------------------------------------------------------------------------

# NextAuth
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=              # openssl rand -base64 32

# Platform database (shares the same Postgres by default)
PLATFORM_DATABASE_URL=postgres://bbs:bbs@localhost:5432/bbs

# OAuth (email+password works without these — OAuth wiring is a follow-up)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe
STRIPE_SECRET_KEY=sk_test_
STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_WEBHOOK_SECRET=whsec_
STRIPE_PRICE_STARTER=price_
STRIPE_PRICE_PRO=price_
STRIPE_PRICE_STARTER_YEARLY=price_
STRIPE_PRICE_PRO_YEARLY=price_

# Resend (transactional email)
RESEND_API_KEY=re_
RESEND_FROM_EMAIL=noreply@bigballsports.io

# Next.js public vars (browser-exposed)
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_
NEXT_PUBLIC_WS_URL=ws://localhost:3000
